{
  "name": "@artemiskit/sdk",
  "version": "0.3.2",
  "description": "Programmatic SDK for ArtemisKit LLM evaluation toolkit - integrate into your Node.js apps",
  "type": "module",
  "license": "Apache-2.0",
  "author": "code-sensei",
  "repository": {
    "type": "git",
    "url": "https://github.com/code-sensei/artemiskit.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/code-sensei/artemiskit/issues"
  },
  "homepage": "https://artemiskit.vercel.app",
  "keywords": [
    "llm",
    "testing",
    "sdk",
    "ai",
    "agents",
    "evaluation",
    "openai",
    "anthropic",
    "vitest",
    "jest",
    "red-team",
    "security"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./matchers": {
      "import": "./dist/matchers/index.js",
      "types": "./dist/matchers/index.d.ts"
    },
    "./vitest": {
      "import": "./dist/matchers/vitest.js",
      "types": "./dist/matchers/vitest.d.ts"
    },
    "./jest": {
      "import": "./dist/matchers/jest.js",
      "types": "./dist/matchers/jest.d.ts"
    },
    "./builders": {
      "import": "./dist/builders/index.js",
      "types": "./dist/builders/index.d.ts"
    },
    "./contracts": {
      "import": "./dist/contracts/index.js",
      "types": "./dist/contracts/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./types": {
      "types": "./dist/types-only.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly && bun build ./src/index.ts ./src/matchers/index.ts ./src/matchers/vitest.ts ./src/matchers/jest.ts ./src/builders/index.ts ./src/contracts/index.ts ./src/utils/index.ts ./src/types-only.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@artemiskit/core": "workspace:*",
    "@artemiskit/redteam": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0",
    "@jest/expect": ">=29.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    },
    "@jest/expect": {
      "optional": true
    }
  }
}
